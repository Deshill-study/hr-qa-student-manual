# 环境配置示例文件
# 复制此文件为 .env 并填入真实配置
# ⚠️ .env 文件已加入 .gitignore，不要提交到 Git

# Kimi API（Moonshot AI）
MOONSHOT_API_KEY=sk-your-api-key-here

# Embedding 模型路径（可选）
EMBEDDING_MODEL_PATH=~/.node-llama-cpp/models/nomic-embed-text-v1.5.Q8_0.gguf

# 其他 LLM 配置（可选）
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
